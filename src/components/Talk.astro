---
import { getTalksFormattedDate } from "../lib/helpers";

type Props = {
  id: string;
  title: string;
  date: string;
  place: string;
  eventLink?: string;
  video: {
    videoId: string;
  };
  slidesLink?: string;
};

const { id, video, title, date, eventLink, place, slidesLink } = Astro.props;
---

<article class="flex flex-col overflow-hidden rounded-lg bg-white shadow-md dark:bg-gray-800">
  <div class="grow">
    <a href={`/talks/${id}`} class="relative block overflow-hidden" style="padding-top: 56.25%;">
      <img
        src={`https://img.youtube.com/vi/${video.videoId}/hqdefault.jpg`}
        alt={title}
        class="absolute inset-0 w-full h-full object-cover hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </a>
    <div class="p-6">
      <h4 class="mb-2 text-lg font-bold sm:text-xl leading-7 text-gray-800 dark:text-gray-200">
        <a href={`/talks/${id}`} class="hover:underline">
          {title}
        </a>
      </h4>
      <p class="mb-3 text-sm font-medium text-gray-600 dark:text-gray-400">
        {getTalksFormattedDate(date)} ·{" "}
        <strong>
          {
            eventLink ? (
              <a href={eventLink} target="_blank" rel="noreferrer" class="hover:underline">
                {place}
              </a>
            ) : (
              place
            )
          }
        </strong>
      </p>
      <div class="leading-relaxed text-gray-600 dark:text-gray-400">
        <slot />
      </div>
    </div>
  </div>
  <div class="p-6 text-right">
    <a
      href={`https://www.youtube.com/watch?v=${video.videoId}`}
      target="_blank"
      rel="noreferrer"
      class="group inline-flex items-center justify-center gap-2 rounded-lg border border-blue-700 bg-blue-700 px-7 py-3.5 text-sm font-semibold text-white hover:border-blue-600 hover:bg-blue-600 hover:text-white focus:ring focus:ring-blue-400/50 active:border-blue-700 active:bg-blue-700 dark:focus:ring-blue-400/90"
    >
      <span>Video</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 16 16"
        fill="currentColor"
        class="hi-micro hi-play-circle inline-block size-4"
      >
        <path
          fill-rule="evenodd"
          d="M8 15A7 7 0 1 0 8 1a7 7 0 0 0 0 14Zm-.847-9.766A.75.75 0 0 0 6 5.866v4.268a.75.75 0 0 0 1.153.633l3.353-2.134a.75.75 0 0 0 0-1.266L7.153 5.234Z"
          clip-rule="evenodd"></path>
      </svg>
    </a>
    {
      slidesLink && (
        <a
          href={slidesLink}
          target="_blank"
          rel="noreferrer"
          class="group inline-flex items-center justify-center gap-2 rounded-lg border border-blue-700 bg-blue-700 px-7 py-3.5 text-sm font-semibold text-white hover:border-blue-600 hover:bg-blue-600 hover:text-white focus:ring focus:ring-blue-400/50 active:border-blue-700 active:bg-blue-700 dark:focus:ring-blue-400/90"
        >
          <span>Slides</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 16 16"
            fill="currentColor"
            class="hi-micro hi-document-chart-bar inline-block size-4"
          >
            <path
              fill-rule="evenodd"
              d="M4 2a1.5 1.5 0 0 0-1.5 1.5v9A1.5 1.5 0 0 0 4 14h8a1.5 1.5 0 0 0 1.5-1.5V6.621a1.5 1.5 0 0 0-.44-1.06L9.94 2.439A1.5 1.5 0 0 0 8.878 2H4Zm6 5.75a.75.75 0 0 1 1.5 0v3.5a.75.75 0 0 1-1.5 0v-3.5Zm-2.75 1.5a.75.75 0 0 1 1.5 0v2a.75.75 0 0 1-1.5 0v-2Zm-2 .75a.75.75 0 0 0-.75.75v.5a.75.75 0 0 0 1.5 0v-.5a.75.75 0 0 0-.75-.75Z"
              clip-rule="evenodd"
            />
          </svg>
        </a>
      )
    }
  </div>
</article>
