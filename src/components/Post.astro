---
import { Image } from "astro:assets";
import { getFormattedDate } from "../lib/helpers";

type Props = {
  id: string;
  category: string;
  title: string;
  date: string;
  readingTime: number;
  excerpt: string;
};

const { id, category, title, date, readingTime, excerpt } = Astro.props;
const lowerCaseCategory = category.toLowerCase();

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/posts/*.{png,jpg,jpeg,webp}",
);
const thumbPathPrefix = `../assets/posts/${id}-thumb.`;
const thumbKey = Object.keys(images).find((key) =>
  key.startsWith(thumbPathPrefix),
);
const imageModule =
  (thumbKey ? images[thumbKey] : undefined) ??
  images["../assets/posts/default-thumb.jpg"];
const ImageThumb = (await imageModule()).default;
---

<article
  class="group relative flex flex-col overflow-hidden rounded-lg bg-white shadow-md hover:shadow-xl transition-all duration-300 ease-out hover:scale-[1.02] motion-reduce:transition-none motion-reduce:hover:scale-100 dark:bg-gray-800 h-full"
>
  <div class="relative block w-full overflow-hidden aspect-video">
    <Image
      src={ImageThumb}
      alt={`${title} thumbnail`}
      class="w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-110 motion-reduce:transition-none motion-reduce:group-hover:scale-100"
    />
  </div>
  <div class="flex flex-col grow p-6">
    <div class="mb-3">
      <a
        href={`/blog/${lowerCaseCategory}`}
        aria-label={`View all ${category} posts`}
        class="relative z-10 inline-flex rounded-full bg-blue-100 px-3 py-1.5 text-xs font-semibold uppercase tracking-wide text-blue-800 hover:bg-blue-200 hover:text-blue-900 transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 dark:bg-blue-900/75 dark:text-blue-200 dark:hover:bg-blue-800/75 dark:hover:text-blue-100 dark:focus-visible:ring-blue-400 dark:focus-visible:ring-offset-gray-800"
      >
        {category}
      </a>
    </div>
    <h3 class="mb-3 text-xl md:text-2xl font-bold leading-tight tracking-tight">
      <a
        href={`/blog/${lowerCaseCategory}/${id}`}
        class="text-gray-800 hover:text-blue-600 transition-colors duration-200 dark:text-gray-100 dark:hover:text-blue-400 before:absolute before:inset-0 before:z-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-500 focus-visible:ring-offset-2 focus-visible:relative focus-visible:z-10 dark:focus-visible:ring-blue-400 dark:focus-visible:ring-offset-gray-800"
      >
        {title}
      </a>
    </h3>
    <p class="mb-4 text-sm md:text-base text-gray-600 dark:text-gray-400">
      <time datetime={date} class="font-semibold">{getFormattedDate(date)}</time
      > · {readingTime} min read
    </p>
    <p
      class="mb-6 text-base leading-relaxed text-gray-600 dark:text-gray-400 grow"
    >
      {excerpt}...
    </p>
    <div
      aria-hidden="true"
      class="inline-flex items-center gap-2 text-blue-600 dark:text-blue-400 font-semibold text-sm group-hover:text-blue-700 dark:group-hover:text-blue-300 transition-colors duration-200"
    >
      Read Post
      <svg
        class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1 motion-reduce:transition-none motion-reduce:group-hover:translate-x-0"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
        aria-hidden="true"
        focusable="false"
      >
        <path
          fill-rule="evenodd"
          d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
          clip-rule="evenodd"></path>
      </svg>
    </div>
  </div>
</article>
