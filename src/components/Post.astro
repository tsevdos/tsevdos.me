---
import { Image } from "astro:assets";
import { getFormattedDate } from "../lib/helpers";

type Props = {
  id: string;
  category: string;
  title: string;
  date: string;
  readingTime: number;
  excerpt: string;
};

const { id, category, title, date, readingTime, excerpt } = Astro.props;
const lowerCaseCategory = category.toLowerCase();

const images = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/posts/*.{png,jpg,jpeg,webp}",
);
const thumbPathPrefix = `../assets/posts/${id}-thumb.`;
const thumbKey = Object.keys(images).find((key) =>
  key.startsWith(thumbPathPrefix),
);
const imageModule =
  (thumbKey ? images[thumbKey] : undefined) ??
  images["../assets/posts/default-thumb.jpg"];
const ImageThumb = (await imageModule()).default;
---

<article
  class="group flex flex-col overflow-hidden rounded-lg bg-white shadow-md hover:shadow-xl transition-all duration-300 ease-out hover:scale-[1.02] dark:bg-gray-800 h-full"
>
  <a
    href={`/blog/${lowerCaseCategory}/${id}`}
    class="relative block w-full overflow-hidden aspect-video"
  >
    <Image
      src={ImageThumb}
      alt={`${title} thumbnail`}
      class="w-full h-full object-cover transition-transform duration-300 ease-out group-hover:scale-110"
    />
  </a>
  <div class="flex flex-col grow p-6">
    <div class="mb-3">
      <a
        href={`/blog/${lowerCaseCategory}`}
        class="inline-flex rounded-full bg-blue-100 px-3 py-1 text-xs leading-4 font-semibold text-blue-800 hover:bg-blue-200 hover:text-blue-900 transition-colors duration-200 dark:bg-blue-900/75 dark:text-blue-200 dark:hover:bg-blue-800/75 dark:hover:text-blue-100"
        onclick="event.stopPropagation()"
      >
        {category}
      </a>
    </div>
    <h3 class="mb-2 text-xl font-bold leading-tight">
      <a
        href={`/blog/${lowerCaseCategory}/${id}`}
        class="text-gray-800 hover:text-blue-600 transition-colors duration-200 dark:text-gray-100 dark:hover:text-blue-400"
      >
        {title}
      </a>
    </h3>
    <p class="mb-3 text-sm text-gray-600 dark:text-gray-400">
      <span class="font-medium">{getFormattedDate(date)}</span> · {readingTime} min
      read
    </p>
    <p class="mb-4 leading-relaxed text-gray-600 dark:text-gray-400 grow">
      {excerpt}...
    </p>
    <a
      href={`/blog/${lowerCaseCategory}/${id}`}
      class="inline-flex items-center gap-2 text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 font-semibold text-sm transition-colors duration-200 group/link"
    >
      Read Post
      <svg
        class="w-4 h-4 transition-transform duration-200 group-hover/link:translate-x-1"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M3 10a.75.75 0 01.75-.75h10.638L10.23 5.29a.75.75 0 111.04-1.08l5.5 5.25a.75.75 0 010 1.08l-5.5 5.25a.75.75 0 11-1.04-1.08l4.158-3.96H3.75A.75.75 0 013 10z"
          clip-rule="evenodd"></path>
      </svg>
    </a>
  </div>
</article>
