---
import { render } from "astro:content";
import type { GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.tsx";
import Footer from "../../components/Footer.astro";
import Talk from "../../components/Talk.astro";
import MobilePagination from "../../components/MobilePagination.astro";
import DesktopPagination from "../../components/DesktopPagination.astro";
import {
  getCollectionsStaticPaths,
  getPagination,
  getAllTalksSorted,
  getPageFromCollection,
} from "../../lib/helpers";

const sortedTalks = await getAllTalksSorted();
const totalTalks = sortedTalks.length;

export const getStaticPaths = (async () => {
  const paths = getCollectionsStaticPaths(totalTalks);

  return paths.map((pageNum) => ({ params: { pageNum } }));
}) satisfies GetStaticPaths;

const { pageNum } = Astro.params as { pageNum: string };
const { href } = Astro.url;
const pageNumInt = parseInt(pageNum ?? "1", 10);
const { currentPage, noOfPages } = getPagination(pageNumInt, totalTalks);
const pageTalks = getPageFromCollection(sortedTalks, pageNumInt) as CollectionEntry<"talks">[];
const talksWithContent = await Promise.all(
  pageTalks.map(async (talk) => {
    const { Content } = await render(talk);
    return { ...talk, Content };
  }),
);
---

<Layout
  title="Public Speaking"
  description="Speaking at events, meetups, and conferences"
  url={href}
>
  <Header client:load />

  <div class="container mx-auto px-4 py-8 sm:px-6 md:py-12 lg:px-8 xl:max-w-7xl">
    <header class="mb-8">
      <h1
        class="mb-3 text-4xl sm:text-5xl lg:text-6xl font-black leading-tight text-black dark:text-white"
      >
        Talks 🥳
      </h1>
      <h2 class="text-xl sm:text-2xl font-medium leading-relaxed text-gray-700 dark:text-gray-300">
        Speaking at events, meetups, and conferences
      </h2>
    </header>

    <!-- Talks  -->
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-2 lg:gap-8">
      {
        talksWithContent.map(
          ({ id, Content, data: { title, eventLink, date, event, video, slidesLink } }) => (
            <Talk
              id={id}
              title={title}
              date={date}
              event={event}
              eventLink={eventLink}
              video={video}
              slidesLink={slidesLink}
            >
              <Content />
            </Talk>
          ),
        )
      }
    </div>
    <!-- END Talks  -->

    <!-- Pagination -->
    <div class="grow mt-10 pt-6">
      <div class="text-center dark:text-gray-100">
        <MobilePagination
          currentPage={currentPage}
          noOfPages={noOfPages}
          totalPosts={totalTalks}
          basePath="/talks"
        />
        <DesktopPagination
          currentPage={currentPage}
          noOfPages={noOfPages}
          totalPosts={totalTalks}
          basePath="/talks"
        />
      </div>
    </div>
    <!-- END Pagination -->
  </div>

  <Footer />
</Layout>
