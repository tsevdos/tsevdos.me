---
import type { GetStaticPaths } from "astro";
import Layout from "../../../../layouts/Layout.astro";
import Header from "../../../../components/Header";
import Footer from "../../../../components/Footer.astro";
import MobilePagination from "../../../../components/MobilePagination.astro";
import DesktopPagination from "../../../../components/DesktopPagination.astro";
import {
  getAllPostsFromCategory,
  getAllCategories,
  getPageFromCollection,
  getPostWithExtras,
  getCollectionsStaticPaths,
  getPagination,
} from "../../../../lib/helpers";
import Post from "../../../../components/Post.astro";

export const getStaticPaths = (async () => {
  const categories = await getAllCategories();
  const paths = [];

  for (const category of categories) {
    const categoryPosts = await getAllPostsFromCategory(category);
    const pageNumbers = getCollectionsStaticPaths(categoryPosts.length);

    const categoryPaths = pageNumbers
      .filter((pageNum) => pageNum !== "1") // Skip page 1 since it's handled by the main category index
      .map((pageNum) => ({ params: { category, pageNum } }));

    paths.push(...categoryPaths);
  }

  return paths;
}) satisfies GetStaticPaths;

const { category, pageNum } = Astro.params as {
  category: string;
  pageNum: string;
};
const { href } = Astro.url;
const categoryPosts = await getAllPostsFromCategory(category);
const totalPosts = categoryPosts.length;
const pageNumInt = parseInt(pageNum ?? "1", 10);
const categoryPagePosts = getPageFromCollection<"posts">(categoryPosts, pageNumInt);
const postsWithExtras = getPostWithExtras(categoryPagePosts);
const { currentPage, noOfPages } = getPagination(pageNumInt, totalPosts);
---

<Layout
  title={`John Tsevdos Blog - ${category} category (page ${currentPage})`}
  description={`${category} posts by John Tsevdos (page ${currentPage})`}
  url={href}
>
  <Header client:load />

  <div class="container mx-auto px-4 py-12 md:py-16 lg:px-8 xl:max-w-7xl">
    <!-- Heading -->
    <header class="mb-8 md:mb-12">
      <h1
        class="mb-3 md:mb-4 text-4xl sm:text-5xl lg:text-6xl font-black leading-tight text-black dark:text-white"
      >
        Blog: {category} Posts 📔
      </h1>
      <h2 class="text-xl sm:text-2xl font-medium leading-relaxed text-gray-700 dark:text-gray-300">
        Sharing ideas and code (<a
          href="/blog/rss.xml"
          class="text-blue-600 hover:text-blue-500 transition-colors dark:text-blue-400 dark:hover:text-blue-300"
          >RSS</a
        > available)
      </h2>
    </header>
    <!-- END Heading -->

    <!-- Blog Posts -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6 lg:gap-8">
      {
        postsWithExtras.map(({ id, data: { category, title, date }, readingTime, excerpt }) => (
          <Post
            id={id}
            category={category}
            title={title}
            date={date}
            readingTime={readingTime}
            excerpt={excerpt}
          />
        ))
      }
    </div>
    <!-- END Blog Posts -->

    <!-- Footer -->
    {
      noOfPages > 1 && (
        <div class="grow border-t border-gray-200 py-5 dark:border-gray-700">
          <div class="text-center dark:text-gray-100">
            <MobilePagination
              currentPage={currentPage}
              noOfPages={noOfPages}
              totalPosts={totalPosts}
              category={category}
              basePath="/blog"
            />
            <DesktopPagination
              currentPage={currentPage}
              noOfPages={noOfPages}
              totalPosts={totalPosts}
              category={category}
              basePath="/blog"
            />
          </div>
        </div>
      )
    }
    <!-- END Footer -->
  </div>

  <Footer />
</Layout>
