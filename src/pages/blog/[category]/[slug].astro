---
import type { GetStaticPaths } from "astro";
import { getEntry, render } from "astro:content";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/Header";
import Footer from "../../../components/Footer.astro";
import { Image } from "astro:assets";
import defaultImage from "../../../assets/posts/default.jpg";
import {
  getAllPostsSorted,
  getFormattedDate,
  getReadingTime,
  stripMdxToPlainText,
} from "../../../lib/helpers";

export const getStaticPaths = (async () => {
  const sortedPosts = await getAllPostsSorted();

  return sortedPosts.map(({ id, data }) => ({
    params: {
      category: data.category.toLowerCase(),
      slug: id,
    },
  }));
}) satisfies GetStaticPaths;

const { slug } = Astro.params as { slug: string };
const { href } = Astro.url;

const post = await getEntry("posts", slug);

// Dynamically import post-specific image or use default
const images = import.meta.glob<{ default: ImageMetadata }>(
  "../../../assets/posts/*.{png,jpg,jpeg,webp}",
  {
    eager: true,
  },
);
const imagePathPrefix = `../../../assets/posts/${slug}.`;
const imageKey = Object.keys(images).find((key) =>
  key.startsWith(imagePathPrefix),
);
const heroImage =
  (imageKey
    ? (images[imageKey]?.default as ImageMetadata | undefined)
    : undefined) || defaultImage;

if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await render(post);
const plainText = stripMdxToPlainText(post.body);
const readingTime = getReadingTime(plainText);
const { title, date, category } = post.data;
---

<Layout
  title={`John Tsevdos Blog - ${title}`}
  description={`John Tsevdos Blog - ${title}`}
  url={href}
>
  <Header client:load />

  <div class="container mx-auto px-4 py-12 md:py-16 lg:px-8 xl:max-w-7xl">
    <header class="mb-6 md:mb-8">
      <h1
        class="mb-4 md:mb-6 text-3xl sm:text-4xl lg:text-5xl font-black leading-tight text-black dark:text-white"
      >
        {title}
      </h1>
      <p
        class="text-base md:text-lg leading-relaxed font-medium text-gray-700 dark:text-gray-300"
      >
        <span class="font-bold tracking-wide text-blue-600 dark:text-blue-500">
          {category}
        </span> · <span class="font-semibold">{getFormattedDate(date)}</span> · {
          readingTime
        } min read
      </p>
    </header>

    <div class="mb-8 md:mb-12">
      <Image
        src={heroImage}
        alt={title}
        class="w-full h-auto rounded-lg shadow-md"
        loading="eager"
      />
    </div>

    <article
      class="max-w-none prose prose-base md:prose-lg lg:prose-xl dark:prose-invert prose-headings:font-bold prose-headings:tracking-tight prose-a:text-blue-600 prose-a:no-underline prose-a:hover:text-blue-400 prose-a:transition-colors dark:prose-a:text-blue-400 dark:prose-a:hover:text-blue-300 prose-img:rounded-lg prose-img:shadow-md prose-pre:bg-gray-900 prose-pre:shadow-lg dark:prose-pre:bg-gray-950"
    >
      <Content />
    </article>
  </div>

  <Footer />
</Layout>
